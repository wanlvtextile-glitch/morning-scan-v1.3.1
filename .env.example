# ── 雪球登录 Cookie（必填，采集雪球数据用）───────────────────
# 从浏览器开发者工具 → Network → 任意 xueqiu.com 请求 → Request Headers → Cookie 复制
XUEQIU_COOKIE=

# ── Agent 层开关 ─────────────────────────────────────────────
# 填入 API Key 并将此项改为 true 后，Agent 层自动补全正宗度/结论/个股
AGENT_LAYER_ENABLED=false

# ── LLM 服务商（选择一种，取消对应注释并填入 Key）────────────
#
# 选项 1：DeepSeek（platform.deepseek.com，充值约 ¥10 可跑数百次）
# LLM_PROVIDER=openai
# LLM_MODEL=deepseek-chat
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.deepseek.com/v1
#
# 选项 2：智谱 AI / GLM（open.bigmodel.cn，glm-4-flash 有免费额度）
# LLM_PROVIDER=openai
# LLM_MODEL=glm-4-flash
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
#
# 选项 3：Anthropic Claude（console.anthropic.com，Key 格式 sk-ant-api03-...）
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=
#
# 选项 4：其他 OpenAI-compatible 服务商（小米 / MiniMax / 月之暗面 / 硅基流动等）
# 填入服务商提供的 Base URL 和模型名即可，无需改动代码
# LLM_PROVIDER=openai
# LLM_MODEL=<服务商模型名，如 abab6.5s-chat>
# OPENAI_API_KEY=
# OPENAI_BASE_URL=<服务商 Base URL>
