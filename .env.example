# 雪球主源
# 浏览器登录 xueqiu.com 后，在 Network -> 任意 xueqiu 请求 -> Request Headers 中复制 Cookie
XUEQIU_COOKIE=

# ZSXQ 主源
# 以下字段来自已登录知识星球网页版的 topics 请求头
ZSXQ_AUTHORIZATION=
ZSXQ_USER_AGENT=
ZSXQ_X_VERSION=
ZSXQ_X_SIGNATURE=
ZSXQ_X_ADUID=

# 可选：当前代码会自动刷新 X-Timestamp / X-Request-Id。
# 如果你需要临时覆盖，也可以手动填写。
ZSXQ_X_TIMESTAMP=
ZSXQ_X_REQUEST_ID=
ZSXQ_COOKIE=
ZSXQ_REFERER=https://wx.zsxq.com/

# Twitter / Telegram 当前已在 source_registry 中关闭，仅保留占位
APIFY_TOKEN=

# Agent / LLM
# morning-scan 的最终交付要求必须由 LLM 参与出最终报告，因此这里必须启用
AGENT_LAYER_ENABLED=true

# 方案 1：DeepSeek / 智谱 / 其他 OpenAI-compatible
LLM_PROVIDER=openai
LLM_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# 方案 2：Anthropic
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=
