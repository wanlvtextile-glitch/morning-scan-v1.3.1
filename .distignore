# 分发边界定义 — 以下文件/目录不进入分发包

# 开发者内部文档
CLAUDE.md
context.md
handoff.md
todo.md
AGENTS.md
architecture.md

# 归档目录
archive/
docs/

# 运行时产物（用户自行生成）
raw_news.json
analysis_result.json
*-scan_result.json
reports/*.md
!reports/.gitkeep

# 密钥与本地配置（用户自行填写）
.env

# Python 缓存
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# 测试目录（仅保留在开发环境）
tests/

# 开发依赖
requirements-dev.txt

# 版本控制
.git/
.gitignore
