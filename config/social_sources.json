{
  "twitter": {
    "enabled": true,
    "query_mode_first": true,
    "apify_token_env": "APIFY_TOKEN",
    "actor_id": "altimis/scweet",
    "max_items_per_run": 80,
    "search_queries": [
      "A股 OR 港股 OR 美股 OR 股票 OR 大盘 OR 板块 OR 龙头 OR 题材",
      "财报 OR 业绩 OR 涨停 OR 跌停 OR 机构 OR 游资 OR 北向资金 OR 南向资金",
      "$NVDA OR $TSLA OR $AAPL OR $MSFT OR $META OR 半导体 OR AI OR 算力 OR 新能源",
      "China stocks OR Hong Kong stocks OR US stocks OR ADR OR earnings OR guidance"
    ],
    "users": [
      "unusual_whales",
      "DeItaone",
      "StockMKTNewz",
      "FirstSquawk"
    ]
  },
  "telegram": {
    "enabled": true,
    "max_messages_per_channel": 20,
    "channels": [
      "FinancialJuice",
      "WalterBloomberg",
      "zerohedge_official"
    ]
  },
  "market_filters": {
    "keywords": [
      "A股",
      "港股",
      "美股",
      "股票",
      "股价",
      "板块",
      "题材",
      "龙头",
      "财报",
      "业绩",
      "机构",
      "游资",
      "北向资金",
      "南向资金",
      "ETF",
      "半导体",
      "AI",
      "算力",
      "新能源",
      "医药",
      "证券",
      "银行",
      "消费电子",
      "特斯拉",
      "英伟达",
      "苹果"
    ],
    "stock_code_patterns": [
      "\\b[036][0-9]{5}\\b",
      "\\bBJ[0-9]{6}\\b",
      "\\$[A-Z]{1,5}\\b"
    ]
  }
}
